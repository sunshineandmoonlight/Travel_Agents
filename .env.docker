# ========================================
# TravelAgents v3.0 Docker 环境配置
# 智能旅行规划系统
# ========================================

# ----------------------------------------
# 数据库配置 (Docker网络)
# ----------------------------------------
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=travel123
MONGODB_DATABASE=travel_agents
MONGODB_AUTH_SOURCE=admin

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=travel123
REDIS_DB=0

# ----------------------------------------
# API 配置
# ----------------------------------------
API_HOST=0.0.0.0
API_PORT=8005
CORS_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:5173

# ----------------------------------------
# LLM 配置 (至少配置一个)
# ----------------------------------------
# DeepSeek V3 (推荐)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 或者使用阿里云 DashScope
# DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 或者使用 OpenAI 兼容接口
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# ----------------------------------------
# 日志配置
# ----------------------------------------
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# ----------------------------------------
# 外部 API 配置 (可选)
# ----------------------------------------
# 天行数据（国内景点）
TIANAPI_TOKEN=your-tianapi-token-here

# OpenTripMap（国际景点）
OPENTRIPMAP_API_KEY=your-opentripmap-key-here

# Unsplash（图片）
UNSPLASH_ACCESS_KEY=your-unsplash-key-here

# ----------------------------------------
# Celery 配置 (异步任务)
# ----------------------------------------
CELERY_BROKER_URL=redis://:travel123@redis:6379/0
CELERY_RESULT_BACKEND=redis://:travel123@redis:6379/0

# ----------------------------------------
# JWT 认证配置
# ----------------------------------------
JWT_SECRET=change-this-to-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=43200

# ----------------------------------------
# 环境标识
# ----------------------------------------
DOCKER_CONTAINER=true
ENVIRONMENT=production
